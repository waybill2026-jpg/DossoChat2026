<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>DossoChat26</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.2/photoswipe.min.css">
    <style>

    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#050505">
    <link rel="apple-touch-icon" href="/assets/icons/logo.png">

        :root {
            --bg-black: #000000; /* Zemin */
            --sidebar-bg: #0f1418;
            --outgoing-msg: #1A53FF; /* PROJE RAPORUNDAKİ CİVİT MAVİ (SAĞ) */
            --incoming-msg: #2C2C2E; /* PROJE RAPORUNDAKİ KOYU GRİ (SOL) */
            --text-main: #f5f5f5;
        }

        body, html {
            height: 100%;
            margin: 0;
            background-color: var(--bg-black);
            color: var(--text-main);
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        /* Diğer CSS'lerin aynı kalabilir, yukarıdaki renkler balonlara otomatik yansır */
        .chat-container {
            display: flex;
            height: 100vh;
            width: 100vw;
            background: var(--bg-black);
        }

        .chat-sidebar {
            width: 350px;
            background: var(--sidebar-bg);
            border-right: 1px solid #1c242b;
            display: flex;
            flex-direction: column;
            z-index: 10;
            transition: 0.3s;
        }

        .chat-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--bg-black);
            position: relative;
            transition: 0.3s;
        }

        .messages-wrapper {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
            background-blend-mode: overlay;
            background-color: #000;
        }

        .msg {
            max-width: 80%;
            padding: 8px 12px;
            border-radius: 12px;
            margin-bottom: 6px;
            position: relative;
            font-size: 15px;
        }

        .msg-in {
            background: var(--incoming-msg);
            align-self: flex-start;
            border-bottom-left-radius: 2px;
        }

        .msg-out {
            background: var(--outgoing-msg);
            align-self: flex-end;
            border-bottom-right-radius: 2px;
        }

        @@media (max-width: 768px) {
            .chat-sidebar {
                width: 100%;
                position: absolute;
                left: 0;
                height: 100%;
            }

            .chat-main {
                width: 100%;
                position: absolute;
                left: 100%;
                height: 100%;
                z-index: 20;
            }

            .mobile-chat-open .chat-sidebar {
                left: -100%;
            }

            .mobile-chat-open .chat-main {
                left: 0;
            }
        }

        .animate-pulse {
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }

            100% {
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <!-- CSRF Koruması (Telegram'a dosya yüklerken hata almamak için önemli) -->
    @Html.AntiForgeryToken()

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Firebase SDK (Version 9 Compat modu senin kodlarınla tam uyumlu) -->
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.2/umd/photoswipe.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/photoswipe/5.4.2/umd/photoswipe-lightbox.umd.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
