<!-- Pages/Shared/_AdminPanel.cshtml -->
<div class="modal fade" id="adminPanelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-warning">
            <div class="modal-header">
                <h5 class="text-warning"><i class="bi bi-shield-lock-fill"></i> Yönetim Paneli</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- YENİ KULLANICI EKLEME FORMU -->
                <div class="row g-2 mb-3 p-3 border border-secondary rounded bg-black">
                    <div class="col-md-3"><input type="text" id="admNewName" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Ad Soyad"></div>
                    <div class="col-md-3"><input type="email" id="admNewEmail" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="E-posta"></div>
                    <div class="col-md-2"><input type="text" id="admNewPass" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Şifre"></div>
                    <div class="col-md-2">
                        <select id="admNewRole" class="form-select form-select-sm bg-dark text-white border-secondary">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="col-md-2"><button class="btn btn-warning btn-sm w-100 fw-bold" onclick="adminCreateUser()">KAYDET</button></div>
                </div>

                <div class="table-responsive" style="max-height: 400px;">
                    <table class="table table-dark table-hover small">
                        <thead>
                            <tr>
                                <th>İsim</th>
                                <th>Email</th>
                                <th>Şifre</th>
                                <th>Yetki</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="userTable">
                            <!-- JS ile dolacak -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>