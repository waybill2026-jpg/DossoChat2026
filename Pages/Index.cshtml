<script>
    let currentCategory = "faces";

    function setCategory(cat) {
        currentCategory = cat;
        document.querySelectorAll('#emojiBox .emoji-item').forEach(el => {
            el.style.display = (el.dataset.cat === cat) ? "inline-block" : "none";
        });
    }

    document.addEventListener("DOMContentLoaded", () => {
        setCategory("faces");
    });
</script>

<!-- GRUP KUR MODAL (İSTEDİĞİN TÜM ÖZELLİKLER BURADA) -->
