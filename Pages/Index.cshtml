<!-- PWA Yükleme Çubuğu (Varsayılan olarak gizli) -->
let deferredPrompt;

window.addEventListener('beforeinstallprompt', (e) => {
    // Chrome'un kendi otomatik kutusunu engelle (bizimkini çıkaracağız)
    e.preventDefault();
    deferredPrompt = e;
    
    // Bizim mavi yükleme çubuğunu göster
    $("#pwaInstallBanner").fadeIn();
});

async function installPWA() {
    if (deferredPrompt) {
        // Yükleme kutusunu tetikle
        deferredPrompt.prompt();
        
        const { outcome } = await deferredPrompt.userChoice;
        if (outcome === 'accepted') {
            console.log('Kullanıcı PWA yüklemeyi kabul etti');
        }
        deferredPrompt = null;
        $("#pwaInstallBanner").fadeOut();
    }
}

// Uygulama yüklendikten sonra çubuğu gizle
window.addEventListener('appinstalled', () => {
    $("#pwaInstallBanner").fadeOut();
    deferredPrompt = null;
});

@section Scripts {
    <script>
        const firebaseConfig = { databaseURL: "https://dossochat-default-rtdb.europe-west1.firebasedatabase.app/" };
        if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
        const fdb = firebase.database();

        let user = JSON.parse(localStorage.getItem("dosso_user") || "null");
        let activeChatId = "Global", selectedMsg = { id: null, text: null, imp: false };
        let rec, chunks = [], timer;

        const translations = {
            TR: { profileHint: "Profil Ayarları", addBtn: "Ekle", groupBtn: "Grup", globalTitle: "Genel Sohbet", online: "çevrimiçi", cancel: "İptal", send: "Gönder", updateBtn: "GÜNCELLE", placeholder: "Mesaj yazın..." },
            UZ: { profileHint: "Profil Sozlamalari", addBtn: "Qo'shish", groupBtn: "Guruh", globalTitle: "Umumiy Chat", online: "onlayn", cancel: "Bekor qilish", send: "Yuborish", updateBtn: "YANGILASH", placeholder: "Xabar yozing..." },
            RUS: { profileHint: "Настройки профиля", addBtn: "Добавить", groupBtn: "Группа", globalTitle: "Общий чат", online: "в сети", cancel: "Отмена", send: "Отправить", updateBtn: "ОБНОВИТЬ", placeholder: "Напишите сообщение..." },
            EN: { profileHint: "Profile Settings", addBtn: "Add", groupBtn: "Group", globalTitle: "Global Chat", online: "online", cancel: "Cancel", send: "Send", updateBtn: "UPDATE", placeholder: "Type a message..." }
        };

        $(document).ready(() => {
            if (!user) { window.location.href = "/Login"; return; }
            if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }
            $("#myName").text(user.DisplayName);
            $("#myAvatar, #profPicPreview").attr("src", user.ProfileImage || "/assets/icons/logo.png");
            if (user.Role === "Admin") $("#adminBtn").show();
            applyLanguage(user.Language || "TR");
            loadMyContacts();
            selectChat('Global', 'Genel Sohbet', '/assets/icons/logo.png');
            $(document).on("click", () => $("#msgContextMenu").hide());
            $("#msgInput").on("keypress", e => { if(e.which===13) sendMsg(); });
        });

        function applyLanguage(lang) {
            const t = translations[lang] || translations.TR;
            $(".lang-profile-hint").text(t.profileHint); $(".lang-add-btn").text(t.addBtn); $(".lang-group-btn").text(t.groupBtn);
            $(".lang-global-title").text(t.globalTitle); $(".lang-online").text(t.online); $(".lang-cancel").text(t.cancel);
            $(".lang-send").text(t.send); $(".lang-update-btn").text(t.updateBtn); $("#msgInput").attr("placeholder", t.placeholder);
        }

        // --- MÜHÜRLÜ SES KAYIT ---
        async function startRecord() {
            const s = await navigator.mediaDevices.getUserMedia({ audio: true });
            rec = new MediaRecorder(s); chunks = [];
            rec.ondataavailable = e => chunks.push(e.data);
            rec.start(); $("#voiceBar").fadeIn();
            let sec = 0; timer = setInterval(() => { sec++; $("#vTimer").text(new Date(sec * 1000).toISOString().substr(14, 5)); }, 1000);
        }
        function stopRecord(send) {
            rec.stop(); clearInterval(timer); $("#voiceBar").fadeOut(); $("#vTimer").text("00:00");
            if(send) fdb.ref("Messages/"+activeChatId).push({ SenderId: user.UserId, SenderName: user.DisplayName, MessageText: "🎤 Sesli Mesaj", Type: "Voice", Timestamp: firebase.database.ServerValue.TIMESTAMP });
        }

        // --- MÜHÜRLÜ MEDYA YÜKLEME ---
        async function uploadMedia() {
            const file = $("#fileInp")[0].files[0]; if(!file) return;
            const formData = new FormData(); formData.append("file", file);
            const res = await fetch('?handler=UploadToTelegram', { method: 'POST', body: formData, headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() } });
            const j = await res.json();
            if(j.success) fdb.ref("Messages/"+activeChatId).push({ SenderId: user.UserId, SenderName: user.DisplayName, MessageText: file.name, DownloadUrl: j.url, Type: "Image", Timestamp: firebase.database.ServerValue.TIMESTAMP });
        }

        // --- MÜHÜRLÜ ARAMA ---
        function filterContacts() {
            const val = $("#contactSearch").val().toLowerCase();
            $(".chat-item-div").each(function() { $(this).toggle($(this).text().toLowerCase().includes(val)); });
        }
        function filterMessages() {
            const val = $("#msgSearch").val().toLowerCase();
            $(".msg").each(function() { $(this).toggle($(this).find(".content").text().toLowerCase().includes(val)); });
        }

        // --- GRUP İŞLEMLERİ ---
        function showGroupModal() { $("#addGroupModal").modal('show'); }
        function processCreateGroup() {
            const name = $("#newGroupName").val();
            const selected = []; $("#groupContactList input:checked").each(function() { selected.push($(this).val()); });
            if(!name || selected.length === 0) { alert("Grup adı ve en az 1 kişi seçin!"); return; }
            alert("Grup '" + name + "' başarıyla kuruldu! (Kişiler: " + selected.length + ")");
            $("#addGroupModal").modal('hide');
        }

        // --- CHAT VE MESAJ ---
        function selectChat(id, name, img) {
            activeChatId = id; $("#chatHeaderName").text(name); $("#chatHeaderImg").attr("src", img); $("#messageArea").html(""); $("#appContainer").addClass("mobile-chat-open");
            fdb.ref("Messages/"+activeChatId).off();
            fdb.ref("Messages/"+activeChatId).on("child_added", s => renderMsg(s));
            fdb.ref("Messages/"+activeChatId).on("child_changed", s => $(`#msg-${s.key}`).replaceWith(renderMsg(s, true)));
            fdb.ref("Messages/"+activeChatId).on("child_removed", s => $(`#msg-${s.key}`).remove());
        }

        function renderMsg(s, isUpd = false) {
            const d = s.val(), isMe = d.SenderId === user.UserId;
            let content = d.MessageText;
            if(d.Type === "Image") content = `<img src="${d.DownloadUrl}" class="rounded w-100 shadow" style="max-width:250px" onclick="window.open('${d.DownloadUrl}')">`;
            const html = `<div class="msg ${isMe?'msg-out':'msg-in'} ${d.isImportant?'msg-important':''} p-2 mb-2 shadow-sm" id="msg-${s.key}" oncontextmenu="handleCtx(event,'${s.key}','${d.MessageText}',${d.isImportant||false})">
                <small class="d-block fw-bold" style="font-size:10px; opacity:0.7">${isMe?'Siz':d.SenderName}</small>
                <div class="content">${content}</div>
                <small class="d-block text-end" style="font-size:9px; opacity:0.5">${new Date(d.Timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</small>
            </div>`;
            if(!isUpd) { $("#messageArea").append(html); $("#messageArea").scrollTop($("#messageArea")[0].scrollHeight); }
            return html;
        }

        function handleCtx(e, k, t, i) { e.preventDefault(); selectedMsg={id:k, text:t, imp:i}; $("#msgContextMenu").css({top:e.pageY, left:e.pageX}).fadeIn(100); }
        function copyMsg() { navigator.clipboard.writeText(selectedMsg.text); $("#msgContextMenu").hide(); }
        function deleteMsg() { if(confirm("Silinsin mi?")) fdb.ref(`Messages/${activeChatId}/${selectedMsg.id}`).remove(); }
        function editMsg() { const nt = prompt("Düzenle:", selectedMsg.text); if(nt) fdb.ref(`Messages/${activeChatId}/${selectedMsg.id}`).update({MessageText: nt}); }
        function toggleImportant() { fdb.ref(`Messages/${activeChatId}/${selectedMsg.id}`).update({isImportant: !selectedMsg.imp}); }

        function sendMsg() { const v = $("#msgInput").val().trim(); if(!v) return; fdb.ref("Messages/"+activeChatId).push({SenderId:user.UserId, SenderName:user.DisplayName, MessageText:v, Type:"Text", Timestamp:firebase.database.ServerValue.TIMESTAMP}); $("#msgInput").val("").focus(); }

        // --- REHBER VE ADMİN ---
        function loadMyContacts() {
            fdb.ref(`Users/${user.UserId}/Contacts`).on('value', s => {
                let h = "", g = "";
                s.forEach(c => {
                    const v = c.val();
                    h += `<div class="p-3 d-flex align-items-center border-bottom border-dark chat-item-div" style="cursor:pointer" onclick="selectChat('${v.UserId}','${v.DisplayName}','${v.ProfileImage}')"><img src="${v.ProfileImage}" width="40" height="40" class="rounded-circle me-3 border border-secondary shadow-sm"><div class="text-white"><strong>${v.DisplayName}</strong></div></div>`;
                    g += `<div class="contact-select-item d-flex align-items-center text-white"><input type="checkbox" value="${v.UserId}" id="chk_${v.UserId}" class="form-check-input me-3 shadow-none"> <label for="chk_${v.UserId}" style="cursor:pointer">${v.DisplayName}</label></div>`;
                });
                $("#dynamicContacts").html(h); $("#groupContactList").html(g || "Rehber boş");
            });
        }

        function adminCreateUser() {
            const n=$("#admNewName").val(), e=$("#admNewEmail").val(), p=$("#admNewPass").val(), r=$("#admNewRole").val();
            const ref = fdb.ref("Users").push();
            ref.set({ UserId: ref.key, DisplayName: n, Email: e, Password: p, Role: r, IsApproved: true, ProfileImage: "/assets/icons/logo.png" }).then(() => { alert("Eklendi"); showAdminPanel(); });
        }

        function showAdminPanel() { $("#adminPanelModal").modal('show'); fdb.ref("Users").once('value', s => { let h = ""; s.forEach(u => { const v = u.val(); h += `<tr><td>${v.DisplayName}</td><td>${v.Email}</td><td>${v.Role}</td><td><button class="btn btn-sm btn-danger" onclick="fdb.ref('Users/${u.key}').remove(); showAdminPanel();">Sil</button></td></tr>`; }); $("#userTable").html(h); }); }
        function searchAndAddUser() { const email = $("#searchEmail").val().trim().toLowerCase(); fdb.ref("Users").once('value', s => { s.forEach(u => { const d = u.val(); if(d.Email && d.Email.toLowerCase() === email) fdb.ref(`Users/${user.UserId}/Contacts/${u.key}`).set({UserId:u.key, DisplayName:d.DisplayName, Email:d.Email, ProfileImage:d.ProfileImage || "/assets/icons/logo.png"}); }); alert("Bitti!"); }); }
        function updateMyProfile() { const upds = { DisplayName:$("#profName").val(), Phone:$("#profPhone").val(), Language:$("#profLang").val() }; if($("#profPass").val()) upds.Password = $("#profPass").val(); fdb.ref(`Users/${user.UserId}`).update(upds).then(() => { localStorage.setItem("dosso_user", JSON.stringify({...user, ...upds})); location.reload(); }); }
        function showSettings() { $("#profName").val(user.DisplayName); $("#profPhone").val(user.Phone||""); $("#profEmail").val(user.Email); $("#profLang").val(user.Language||"TR"); $("#settingsModal").modal('show'); }
        function addEmoji(e) { $("#msgInput").val($("#msgInput").val() + e).focus(); $("#emojiBox").hide(); }
        function closeChat() { $("#appContainer").removeClass("mobile-chat-open"); }
        function logout() { localStorage.clear(); window.location.href = "/Login"; }
        function previewImg(i) { if (i.files && i.files[0]) { const r = new FileReader(); r.onload = e => $('#profPicPreview').attr('src', e.target.result); r.readAsDataURL(i.files[0]); } }
    </script>
}
