        <div class="modal-content bg-dark text-white border-primary shadow-lg">
            <div class="modal-header border-secondary"><h5>Yeni Grup Oluştur</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
