@page
@model IndexModel
@{
    Layout = "_Layout";
}
@Html.AntiForgeryToken()

<style>
    :root {
        --civit-mavi: #1A53FF;
        --koyu-gri: #2C2C2E;
        --bg-black: #050505;
        --admin-sari: #FFD700;
    }

    body {
        background-color: var(--bg-black);
        color: white;
        overflow: hidden;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Mühürlü Mesaj Balonları */
    .msg-out {
        background: var(--civit-mavi) !important;
        align-self: flex-end;
        border-radius: 15px 15px 2px 15px !important;
        color: white;
        position: relative;
        max-width: 85%;
        margin-left: auto;
    }

    .msg-in {
        background: var(--koyu-gri) !important;
        align-self: flex-start;
        border-radius: 15px 15px 15px 2px !important;
        color: white;
        position: relative;
        max-width: 85%;
    }

    .msg-important .content {
        color: #ff4444 !important;
        font-weight: 900 !important;
        font-size: 1.2rem !important;
        text-transform: uppercase;
    }

    /* Context Menu */
    .ctx-menu {
        position: fixed;
        background: #233138;
        border-radius: 10px;
        z-index: 5000;
        display: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        min-width: 160px;
        border: 1px solid #333;
    }

    .ctx-item {
        padding: 12px 15px;
        cursor: pointer;
        color: white;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: 0.2s;
    }

        .ctx-item:hover {
            background: #343f45;
            color: var(--civit-mavi);
        }

    /* Mobil Layout */
    @@media (max-width: 768px) {
        .chat-sidebar {
            width: 100%;
            position: absolute;
            left: 0;
            transition: 0.3s;
            z-index: 10;
            height: 100vh;
        }

        .chat-main {
            width: 100%;
            position: absolute;
            left: 100%;
            transition: 0.3s;
            z-index: 20;
            background: #000;
            height: 100vh;
        }

        .mobile-chat-open .chat-sidebar {
            left: -100%;
        }

        .mobile-chat-open .chat-main {
            left: 0;
        }
    }

    .search-box {
        background: #1a1a1a;
        border: none;
        color: white;
        font-size: 13px;
        border-radius: 8px;
    }

    .emoji-item {
        font-size: 28px;
        cursor: pointer;
        padding: 5px;
    }

    .contact-select-item {
        background: #111;
        border-radius: 8px;
        margin-bottom: 5px;
        padding: 10px;
        transition: 0.3s;
    }

        .contact-select-item:hover {
            background: #222;
        }
</style>

<div class="chat-container d-flex" id="appContainer" style="height: 100vh;">

    <!-- SIDEBAR -->
    <div class="chat-sidebar d-flex flex-column bg-black border-end border-dark">
        <div class="p-3 d-flex align-items-center justify-content-between bg-dark border-bottom border-secondary">
            <div class="d-flex align-items-center" onclick="showSettings()" style="cursor:pointer">
                <img id="myAvatar" src="/assets/icons/logo.png" width="45" height="45" class="rounded-circle me-2 border border-info object-fit-cover">
                <div><strong id="myName" class="text-white d-block">...</strong><small class="text-info lang-profile-hint">Profil Ayarları</small></div>
            </div>
            <div class="d-flex gap-2">
                <button id="adminBtn" class="btn text-warning p-0" style="display:none;" onclick="showAdminPanel()"><i class="bi bi-shield-fill-check fs-3"></i></button>
                <button class="btn text-danger p-0 shadow-none" onclick="logout()"><i class="bi bi-door-open fs-4"></i></button>
            </div>
        </div>

        <!-- REHBERDE ARA (YENİ) -->
        <div class="p-2 bg-dark">
            <input type="text" id="contactSearch" class="form-control search-box mb-2" placeholder="Rehberde Ara..." onkeyup="filterContacts()">
            <div class="d-flex gap-2">
                <button class="btn btn-outline-info btn-sm flex-grow-1 lang-add-btn" onclick="$('#addContactModal').modal('show')">Ekle</button>
                <button class="btn btn-outline-primary btn-sm flex-grow-1 lang-group-btn" onclick="showGroupModal()">Grup</button>
            </div>
        </div>

        <div class="flex-grow-1 overflow-auto" id="myContactsList">
            <div class="p-3 d-flex align-items-center border-bottom border-dark chat-item-div" style="cursor:pointer; background:#151e27" onclick="selectChat('Global', 'Genel Sohbet', '/assets/icons/logo.png')">
                <div class="rounded-circle bg-primary p-2 me-3"><i class="bi bi-globe2 fs-4 text-white"></i></div>
                <div class="text-white"><strong class="lang-global-title">Genel Sohbet</strong></div>
            </div>
            <div id="dynamicContacts"></div>
        </div>
    </div>

    <!-- MAIN CHAT -->
    <div class="chat-main d-flex flex-column">
        <div class="p-2 bg-dark d-flex align-items-center shadow border-bottom border-secondary text-white">
            <i class="bi bi-arrow-left fs-3 me-2 d-md-none" onclick="closeChat()"></i>
            <img id="chatHeaderImg" src="/assets/icons/logo.png" width="40" height="40" class="rounded-circle me-2 border border-info">
            <div class="flex-grow-1">
                <h6 class="mb-0 fw-bold" id="chatHeaderName">...</h6>
                <small class="text-success lang-online">çevrimiçi</small>
            </div>
            <!-- CHAT İÇİ ARA (YENİ) -->
            <input type="text" id="msgSearch" class="form-control search-box w-25 d-none d-sm-block" placeholder="Mesaj Ara..." onkeyup="filterMessages()">
        </div>

        <div class="messages-wrapper flex-grow-1 overflow-auto p-3" id="messageArea" style="background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png'); background-blend-mode: overlay; background-color: #000;"></div>

        <!-- SES KAYIT BARI (MÜHÜRLÜ) -->
        <div id="voiceBar" class="bg-dark text-info p-3 border-top border-info shadow" style="display:none;">
            <div class="d-flex align-items-center justify-content-between">
                <div><i class="bi bi-mic-fill text-danger animate-pulse fs-4"></i> <span id="vTimer">00:00</span></div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-danger lang-cancel" onclick="stopRecord(false)">İptal</button>
                    <button class="btn btn-sm btn-success lang-send" onclick="stopRecord(true)">Gönder</button>
                </div>
            </div>
        </div>

        <!-- INPUT ALANI (MÜHÜRLÜ) -->
        <div class="p-2 bg-dark d-flex align-items-center border-top border-secondary">
            <button class="btn text-secondary fs-4" onclick="$('#emojiBox').toggle()"><i class="bi bi-emoji-smile"></i></button>
            <input type="file" id="fileInp" hidden onchange="uploadMedia()">
            <button class="btn text-secondary fs-4" onclick="$('#fileInp').click()"><i class="bi bi-paperclip"></i></button>
            <input type="text" id="msgInput" class="form-control mx-2 bg-black border-secondary text-white shadow-none" placeholder="Mesaj yazın...">
            <button class="btn btn-outline-info rounded-circle me-2" onclick="startRecord()"><i class="bi bi-mic-fill"></i></button>
            <button class="btn btn-primary rounded-circle shadow" onclick="sendMsg()"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>
</div>

<!-- CONTEXT MENU (MÜHÜRLÜ) -->
<div id="msgContextMenu" class="ctx-menu">
    <div class="ctx-item" onclick="copyMsg()"><i class="bi bi-clipboard"></i> <span class="lang-ctx-copy">Kopyala</span></div>
    <div class="ctx-item" onclick="editMsg()"><i class="bi bi-pencil"></i> <span class="lang-ctx-edit">Düzenle</span></div>
    <div class="ctx-item" onclick="toggleImportant()"><i class="bi bi-exclamation-octagon"></i> <span class="lang-ctx-important">Önemli</span></div>
    <div class="ctx-item text-danger border-top border-secondary" onclick="deleteMsg()"><i class="bi bi-trash"></i> <span class="lang-ctx-delete">Sil</span></div>
</div>

