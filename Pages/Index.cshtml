    <div class="modal-dialog modal-xl modal-dialog-centered"><div class="modal-content bg-dark text-white border-warning"><div class="modal-header"><h5>Admin Panel</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-2 mb-3 bg-black p-2 rounded"><div class="col-md-3"><input type="text" id="admNewName" class="form-control bg-dark text-white" placeholder="İsim"></div><div class="col-md-3"><input type="email" id="admNewEmail" class="form-control bg-dark text-white" placeholder="Email"></div><div class="col-md-2"><input type="text" id="admNewPass" class="form-control bg-dark text-white" placeholder="Şifre"></div><div class="col-md-2"><select id="admNewRole" class="form-select bg-dark text-white"><option value="User">User</option><option value="Admin">Admin</option></select></div><div class="col-md-2"><button class="btn btn-warning w-100" onclick="adminCreateUser()">KAYDET</button></div></div><table class="table table-dark table-sm"><thead><tr><th>İsim</th><th>Email</th><th>Yetki</th><th>İşlem</th></tr></thead><tbody id="userTable"></tbody></table></div></div></div>
</div>

<div class="modal fade" id="settingsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-info">
            <div class="modal-body text-center">
                <img id="profPicPreview" src="/assets/icons/logo.png" width="100" height="100" class="rounded-circle border border-info mb-3 object-fit-cover" onclick="$('#profImgInp').click()">
                <input type="file" id="profImgInp" hidden onchange="previewImg(this)">
                <input type="text" id="profName" class="form-control bg-black text-white mb-2" placeholder="İsim">
                <input type="text" id="profPhone" class="form-control bg-black text-white mb-2" placeholder="Telefon">
                <input type="email" id="profEmail" class="form-control bg-dark text-muted mb-2" disabled>
                <select id="profLang" class="form-select bg-black text-white mb-2"><option value="TR">Türkçe</option><option value="UZ">O'zbek</option><option value="RUS">Русский</option><option value="EN">English</option></select>
