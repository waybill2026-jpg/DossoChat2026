@page
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş - DossoChat26</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: #0e1621;
            color: white;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: #17212b;
            padding: 40px;
            border-radius: 20px;
            width: 100%;
            max-width: 400px;
            border: 1px solid #2b5278;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .form-control {
            background: #0e1621 !important;
            color: white !important;
            border: 1px solid #2b5278 !important;
        }

            .form-control:focus {
                border-color: #0088cc;
                box-shadow: none;
            }

        .input-group-text {
            background: #0e1621;
            border: 1px solid #2b5278;
            color: #0088cc;
            cursor: pointer;
        }

        .btn-primary {
            background: #0088cc;
            border: none;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="login-card text-center">
        <img src="/assets/icons/logo.png" width="100" class="mb-3 border border-secondary p-1 bg-light rounded">
        <h3 class="text-info fw-bold mb-4">DossoChat26</h3>

        <div class="text-start">
            <label class="small text-muted mb-1">Email Adresi</label>
            <input type="email" id="email" class="form-control mb-3" placeholder="admin@dossochat.com" value="admin@dossochat.com">

            <label class="small text-muted mb-1">Şifre</label>
            <div class="input-group mb-4">
                <input type="password" id="pass" class="form-control" placeholder="Tr131408" value="Tr131408">
                <span class="input-group-text" onclick="togglePassword()">
                    <i id="eyeIcon" class="bi bi-eye"></i>
                </span>
            </div>

            <button id="loginBtn" class="btn btn-primary w-100 py-2 fw-bold" onclick="doLogin()">
                <span id="btnText">GİRİŞ YAP</span>
                <span id="btnLoader" class="spinner-border spinner-border-sm d-none"></span>
            </button>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
    <script>
        // RTDB Ayarları
        const firebaseConfig = { databaseURL: "https://dossochat-default-rtdb.europe-west1.firebasedatabase.app/" };
        firebase.initializeApp(firebaseConfig);
        const fdb = firebase.database();

        function togglePassword() {
            const p = document.getElementById("pass");
            const i = document.getElementById("eyeIcon");
            if (p.type === "password") { p.type = "text"; i.classList.replace("bi-eye", "bi-eye-slash"); }
            else { p.type = "password"; i.classList.replace("bi-eye-slash", "bi-eye"); }
        }

        async function doLogin() {
            const emailInp = $("#email").val().trim();
            const passInp = $("#pass").val().trim();

            $("#btnText").addClass("d-none");
            $("#btnLoader").removeClass("d-none");

            // KRİTİK DÜZELTME: Yol "Users/Admin" olarak güncellendi
            fdb.ref("Users/Admin").once("value", snap => {
                const u = snap.val();
                console.log("Gelen Veri:", u); // Kontrol için

                if(u && u.Email === emailInp && u.Password === passInp) {
                    localStorage.setItem("dosso_user", JSON.stringify(u));
                    window.location.href = "/Index";
                } else {
                    alert("Hatalı Giriş! Lütfen bilgileri kontrol edin.");
                    $("#btnText").removeClass("d-none");
                    $("#btnLoader").addClass("d-none");
                }
            }).catch(err => {
                alert("Bağlantı Hatası: " + err.message);
                $("#btnText").removeClass("d-none");
                $("#btnLoader").addClass("d-none");
            });
        }

        if(localStorage.getItem("dosso_user")) window.location.href = "/Index";
    </script>
</body>
</html>